# OlasTech Link — Server Configuration
# Copy this file to .env and fill in your real keys

# ─── Server ───────────────────────────────────────────
PORT=8080

# ─── Payment Gateway (Flutterwave) ─────────────────────────────────
# Get these from your Flutterwave Dashboard -> Settings -> API Keys
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx-X

# Your server's public URL (needed for Paystack webhook + Omada redirect)
# Example: http://192.168.1.100:8080 (your server IP on the LAN)
# Or: https://portal.olastech.ng (if you have a domain)
BASE_URL=http://localhost:8080

# ─── TP-Link Omada Controller ─────────────────────────
# Find your controller IP at: http://omada.tplinkcloud.com or your local controller
# Omada Software Controller default: https://192.168.1.1:8043
OMADA_CONTROLLER_URL=https://192.168.1.1:8043
OMADA_SITE_NAME=Default
OMADA_USERNAME=admin
OMADA_PASSWORD=admin

# ─── Database ─────────────────────────────────────────
DB_PATH=./server/olastech.db

# ─── SMTP Email ───────────────────────────────────────
# Create an App Password in your Gmail account, or use Resend/SendGrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=youremail@gmail.com
SMTP_PASS=your-app-password
